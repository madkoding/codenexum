{
  "name": "@codenexum/electron",
  "version": "0.99.3",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "test": "bun test packages/*/test apps/*/test",
    "lint": "tsc -b",
    "version": "bun run scripts/sync-version.ts",
    "dev": "bun run --filter @codenexum/electron dev",
    "package": "bun run --filter @codenexum/electron package"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@codenexum/core": "workspace:*",
    "@codenexum/sql": "workspace:*",
    "lru-cache": "^11",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  }
}