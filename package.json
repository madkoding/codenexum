{
  "name": "@madtech/opencode-context-manager-plugin",
  "version": "2.1.2",
  "description": "opencode plugin for context management in large projects",
  "license": "MIT",
  "main": "plugins/@madtech-opencode-context-manager-plugin.ts",
  "exports": {
    ".": "./plugins/@madtech-opencode-context-manager-plugin.ts",
    "./server": "./plugins/@madtech-opencode-context-manager-plugin.ts"
  },
  "files": [
    "plugins/",
    "src/",
    "skills/",
    "dashboard/dist/"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dashboard:dev": "cd dashboard && bun run dev",
    "dashboard:build": "cd dashboard && bun install && bun run build",
    "prepublishOnly": "bun run dashboard:build",
    "test:pack": "bash scripts/test-pack.sh"
  },
  "engines": {
    "opencode": ">=1.0.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
