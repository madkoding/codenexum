{
  "name": "@codenexum/electron",
  "version": "0.99.10",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:simple": "electron-vite build && electron .",
    "build": "electron-vite build",
    "package": "bun run --filter @codenexum/plugin build && bun run --filter @codenexum/plugin bundle && electron-vite build && electron-builder",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.madkoding.codenexum",
    "productName": "CodeNexum",
    "executableName": "CodeNexum",
    "icon": "build/icon.png",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "build/tray/**/*",
      "../../apps/plugin/dist/index.js",
      "../../apps/plugin/dist/index.bundled.js",
      "../../apps/plugin/dist/index.d.ts",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../apps/plugin",
        "to": "plugin",
        "filter": ["dist/index.js", "dist/index.bundled.js", "dist/index.d.ts", "package.json"]
      },
      {
        "from": "build/tray",
        "to": "tray"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon-linux.png",
      "artifactName": "${productName}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "madKoding",
        "repo": "codenexum"
      }
    ]
  },
  "dependencies": {
    "@codenexum/core": "workspace:*",
    "@codenexum/sql": "workspace:*",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.0",
    "electron": "43.1.0",
    "electron-builder": "^26.15.6",
    "electron-updater": "^6.8.9",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.4"
  }
}
